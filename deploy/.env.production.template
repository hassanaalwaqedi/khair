# ═══════════════════════════════════════════════════
#  Khair Platform — Production Environment
# ═══════════════════════════════════════════════════
# Copy to .env and fill in real values before deploying.
# This file is committed to VCS — .env is NOT.

# ─── Server ──────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=release
ENV=production

# ─── Database ────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=khair
DB_PASSWORD=CHANGE_ME
DB_NAME=khair
DB_SSLMODE=disable

# ─── Redis ───────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# ─── JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
JWT_SECRET=CHANGE_ME
JWT_EXPIRY_HOURS=24

# ─── AI (Gemini) ─────────────────────────────────
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.0-flash

# ─── Email ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@khair.app

# ─── Uploads ─────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ─── CORS ────────────────────────────────────────
FRONTEND_URL=https://khair.app
CORS_ORIGINS=https://khair.app

# ─── Launch Config ───────────────────────────────
LAUNCH_COUNTRY=SA
