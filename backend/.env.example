# ─── Server ──────────────────────────────────
SERVER_PORT=8080
GIN_MODE=debug

# ─── Database (Azure PostgreSQL) ─────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=khair
DB_PASSWORD=<your-db-password>
DB_NAME=khair
DB_SSLMODE=require

# ─── Redis (Azure Cache for Redis) ───────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>
REDIS_TLS=false

# ─── Authentication ──────────────────────────
JWT_SECRET=<min-32-char-secret>
JWT_EXPIRY_HOURS=24

# ─── Logging ─────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── AI (Google Gemini) ──────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.0-flash

# ─── Email (SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email>
SMTP_PASS=<your-app-password>
SMTP_FROM=<your-email>

# ─── Email (SendGrid — optional) ─────────────
SENDGRID_API_KEY=<your-sendgrid-key>
SENDGRID_FROM=noreply@khair.app

# ─── Stripe (Payment — not yet wired) ────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_KEY=
STRIPE_COMMISSION_RATE=0.10

# ─── File Storage ────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── Azure Blob Storage (production) ─────────
AZURE_STORAGE_CONNECTION=<your-azure-storage-connection-string>
AZURE_STORAGE_CONTAINER=uploads
CDN_BASE_URL=

# ─── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=https://khair.app,https://www.khair.app,https://app.khair.app

# ─── Push Notifications (FCM) ────────────────
FCM_SERVER_KEY=<your-fcm-server-key>
