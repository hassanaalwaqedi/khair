# ─── Server ───────────────────────────────
SERVER_PORT=8080
GIN_MODE=release

# ─── Database (PostgreSQL) ────────────────
DB_HOST=your-db-host.postgres.database.azure.com
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=CHANGE_ME
DB_NAME=khair
DB_SSLMODE=require

# ─── Redis ────────────────────────────────
REDIS_HOST=your-redis.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=CHANGE_ME
REDIS_TLS=true

# ─── JWT ──────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRY_HOURS=24

# ─── Logging ─────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

# ─── AI (Gemini) ─────────────────────────
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.0-flash

# ─── Email (SendGrid) ───────────────────
SENDGRID_API_KEY=CHANGE_ME
SENDGRID_FROM=no-reply@khair.it.com

# ─── Uploads ─────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── Azure Blob Storage ──────────────────
AZURE_STORAGE_CONNECTION=CHANGE_ME
AZURE_STORAGE_CONTAINER=uploads

# ─── Frontend URL (CORS) ─────────────────
FRONTEND_URL=https://yourdomain.com

# ─── Sentry (Error Tracking) ─────────────
SENTRY_DSN=
